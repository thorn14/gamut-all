{
  "$schema": "../gamut-all/packages/core/schema.json",
  "$primitives": "./primitives.json",
  "config": {
    "wcagTarget": "AA",
    "complianceEngine": "wcag21",
    "onUnresolvedOverride": "error",
    "stepSelectionStrategy": "mirror-closest",
    "stacks": {
      "nav": 1,
      "modal": 1,
      "tooltip": 1,
      "overlay": 2
    }
  },
  "themes": {
    "light": {
      "ramp": "stone",
      "step": 0,
      "fallback": ["dark"]
    },
    "ambient": {
      "ramp": "stone",
      "step": 0,
      "fallback": ["light"]
    },
    "dark": {
      "ramp": "stone",
      "step": 9,
      "fallback": ["light"]
    }
  },
  "surfaces": {
    "bgBackground":    {"ramp": "stone",  "step": 0},
    "bgMain":          {"ramp": "stone",  "step": 1, "interactions": {"hover": {"step": 2}, "active": {"step": 3}}},
    "bgRaised":        {"ramp": "stone",  "step": 1},
    "bgMuted":         {"ramp": "stone",  "step": 2},
    "bgBrand":         {"ramp": "violet", "step": 4},
    "bgBrandMuted":    {"ramp": "violet", "step": 1},
    "bgDanger":        {"ramp": "red",    "step": 6},
    "bgDangerMuted":   {"ramp": "red",    "step": 1},
    "bgSuccess":       {"ramp": "emerald","step": 6},
    "bgSuccessMuted":  {"ramp": "emerald","step": 1},
    "bgWarning":       {"ramp": "amber",  "step": 7},
    "bgWarningMuted":  {"ramp": "amber",  "step": 1},
    "bgInfo":          {"ramp": "sky",    "step": 6},
    "bgInfoMuted":     {"ramp": "sky",    "step": 1},
    "bgInfoAlt":       {"ramp": "teal",   "step": 6},
    "bgInfoAltMuted":  {"ramp": "teal",   "step": 1},
    "bgDisabled":      {"ramp": "stone",  "step": 1},
    "bgInverse":       {"ramp": "stone",  "step": 9},
    "bgNeutral":       {"ramp": "stone",  "step": 5},
    "bgNeutralMuted":  {"ramp": "stone",  "step": 2}
  },
  "foreground": {
    "fgBrand": {
      "ramp": "violet",
      "defaultStep": 5,
      "interactions": {"hover": {"step": 6}, "active": {"step": 7}}
    },
    "fgBrandAlt": {
      "ramp": "orange",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgDanger": {
      "ramp": "red",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgSuccess": {
      "ramp": "emerald",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgInfo": {
      "ramp": "blue",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgInfoAlt": {
      "ramp": "teal",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgWarning": {
      "ramp": "amber",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 8}}
    },
    "fgDisabled": {
      "ramp": "stone",
      "defaultStep": 4
    },
    "fgMain": {
      "ramp": "stone",
      "defaultStep": 9
    },
    "fgInverse": {
      "ramp": "slate",
      "defaultStep": 0
    },
    "fgDecorative": {
      "ramp": "stone",
      "defaultStep": 5
    },
    "fgAlt": {
      "ramp": "stone",
      "defaultStep": 6,
      "interactions": {"hover": {"step": 7}, "active": {"step": 9}}
    },
    "fgNavAccent": {
      "ramp": "violet",
      "defaultStep": 5
    },
    "fgNavMain": {
      "ramp": "stone",
      "defaultStep": 7,
      "interactions": {"hover": {"step": 9}, "active": {"step": 9}}
    },
    "fgNavDecorative": {
      "ramp": "stone",
      "defaultStep": 5
    }
  },
  "nonText": {
    "borderMain": {
      "ramp": "stone",
      "defaultStep": 5,
      "interactions": {"hover": {"step": 6}, "active": {"step": 7}}
    },
    "borderMuted": {
      "ramp": "stone",
      "defaultStep": 3,
      "decorative": true
    },
    "borderBrand": {
      "ramp": "violet",
      "defaultStep": 5,
      "interactions": {"hover": {"step": 6}, "active": {"step": 7}}
    },
    "borderDanger": {
      "ramp": "red",
      "defaultStep": 6
    },
    "borderSuccess": {
      "ramp": "emerald",
      "defaultStep": 6
    },
    "borderWarning": {
      "ramp": "amber",
      "defaultStep": 7
    },
    "borderInfo": {
      "ramp": "sky",
      "defaultStep": 6
    },
    "borderDisabled": {
      "ramp": "stone",
      "defaultStep": 3
    },
    "focusBrand": {
      "ramp": "violet",
      "defaultStep": 4
    },
    "focusDanger": {
      "ramp": "red",
      "defaultStep": 5
    },
    "focusNeutral": {
      "ramp": "stone",
      "defaultStep": 5
    },
    "focusInverse": {
      "ramp": "slate",
      "defaultStep": 0
    }
  }
}
