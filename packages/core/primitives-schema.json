{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamut-all.dev/schema/primitives.json",
  "title": "Primitives",
  "description": "Color ramp palette for @gamut-all/core following the W3C Design Tokens Format Module 2025.10. Each key is a ramp name; each value is a W3C color group with $type: \"color\" and numbered step tokens with $value.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "$description": { "type": "string" },
    "$extensions": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": {
    "oneOf": [
      {
        "type": "object",
        "description": "W3C Design Tokens color group. Steps are numbered keys (\"0\", \"1\", ...) containing color tokens with $value.",
        "required": ["$type"],
        "properties": {
          "$type": { "type": "string", "const": "color" },
          "$description": { "type": "string" },
          "$extensions": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": {
          "oneOf": [
            {
              "type": "object",
              "required": ["$value"],
              "additionalProperties": false,
              "properties": {
                "$value": {
                  "oneOf": [
                    { "type": "string", "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$", "description": "Hex color shorthand" },
                    { "$ref": "schema.json#/$defs/ColorValue" }
                  ]
                },
                "$description": { "type": "string" },
                "$extensions": { "type": "object", "additionalProperties": true }
              }
            }
          ]
        }
      },
      {
        "type": "array",
        "description": "Legacy format: ordered array of color values (light → dark).",
        "items": {
          "oneOf": [
            { "type": "string", "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$", "description": "Hex color shorthand" },
            { "$ref": "schema.json#/$defs/ColorValue" }
          ]
        }
      }
    ]
  }
}
